<Window x:Class="Denon.DenonSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Denon"
        mc:Ignorable="d"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="Denon AVR Settings" Height="1200" Width="800"
        Left="800"
        Top="100"
        >

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Shared.xaml"/>
                <ResourceDictionary Source="Button.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Style>
        <Style/>
    </Window.Style>

    <Border CornerRadius="15" BorderThickness="3" BorderBrush="Black" Background="Black">
        <Border CornerRadius="10" BorderThickness="5"  >
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush >
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>


            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#555555" Offset="0.0"/>
                        <GradientStop Color="#333333" Offset="0.5"/>
                        <GradientStop Color="#555555" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="550"/>
                </Grid.ColumnDefinitions>

                <Label
                    x:Name="Denon_Settings"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="5,0,0,0"
                    FontSize="30"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" Grid.ColumnSpan="2"
                    >
                    Denon AVR Settings
                </Label>

                <Label
                    x:Name="IP_AddressLabel"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
            
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    IP Address:
                </Label>

                <Label
                    x:Name="PortLabel"
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Port:
                </Label>

                <Label
                    x:Name="NameLabel"
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Name:
                </Label>

                <Label
                    x:Name="SurroundLabel"
                    Grid.Row="4"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Select 1:
                </Label>

                <Label
                    x:Name="StereoLabel"
                    Grid.Row="5"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Select 2:
                </Label>

                <Label
                    x:Name="Select3"
                    Grid.Row="6"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Select 3:
                </Label>

                <Label
                    x:Name="Select4"
                    Grid.Row="7"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Select 4:
                </Label>

                <Label
                    x:Name="V1"
                    Grid.Row="8"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Vol 1:
                </Label>

                <Label
                    x:Name="V2"
                    Grid.Row="9"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Vol 2:
                </Label>

                <Label
                    x:Name="V3"
                    Grid.Row="10"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Vol 3:
                </Label>

                <Label
                    x:Name="V4"
                    Grid.Row="11"
                    Grid.Column="0"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                    Vol 4:
                </Label>

                <TextBox
                    x:Name="IP_AddressBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <TextBox
                    x:Name="PortBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <TextBox
                    x:Name="NameBox"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>
                
                <Grid
                    Grid.Row="4"
                    Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="Number1"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                    <TextBox
                        x:Name="Name1"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                </Grid>

                <Grid
                    Grid.Row="5"
                    Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="Number2"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                    <TextBox
                        x:Name="Name2"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                </Grid>

                <Grid
                    Grid.Row="6"
                    Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="Number3"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                    <TextBox
                        x:Name="Name3"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                </Grid>

                <Grid
                    Grid.Row="7"
                    Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="Number4"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                    <TextBox
                        x:Name="Name4"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        FontSize="40"
                        FontWeight="Medium"
                        Background="#555555"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="3"   
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        >
                    </TextBox>
                </Grid>

                <TextBox
                    x:Name="SetVol1"
                    Grid.Row="8"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <TextBox
                    x:Name="SetVol2"
                    Grid.Row="9"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <TextBox
                    x:Name="SetVol3"
                    Grid.Row="10"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <TextBox
                    x:Name="SetVol4"
                    Grid.Row="11"
                    Grid.Column="1"
                    Margin="5"
                    FontSize="40"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="3"   
    
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    >
                </TextBox>

                <Grid
                    Grid.Row="12"
                    Grid.Column="1"
                    >
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="OK" 
                        Style="{StaticResource ButtonStyle}"
                        Click="OK_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        >OK
                    </Button>

                    <Button
                        x:Name="Cancel" 
                        Style="{StaticResource ButtonStyle}"
                        Click="Cancel_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="1"
                        >Cancel
                    </Button>
                </Grid>
                <TextBlock 
                   x:Name="Copyright"
                   Text="Designed and Created&#x0a;by Georg Black"
                   Grid.Row="12"
                   Grid.Column="0"
                   Margin="0,0,0,0"
                   FontFamily="MV Boli"
                   FontSize="22"
                   Foreground="Lime"
                   TextWrapping="Wrap"
                   LineHeight="10"
                   FontWeight="Normal"
                   TextAlignment="Center">
                </TextBlock>
            </Grid>
        </Border>
    </Border>
</Window>
