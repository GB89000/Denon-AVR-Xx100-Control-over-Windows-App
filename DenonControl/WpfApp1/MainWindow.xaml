<Window x:Class="DenonControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DenonControl"
        mc:Ignorable="d"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="Denon" Width="1000" Height="300"
        Left="300"
        Top="200"
        Icon="/Images/IconDenon.ico" MinWidth="1250" MinHeight="300" 
        >

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Shared.xaml"/>
                <ResourceDictionary Source="Button.xaml"/>
                <ResourceDictionary Source="DataTemplateVectorForms.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Window.Resources>
    <Window.Style>
        <Style/>
    </Window.Style>

    <!--Fenster in der groesse Veraenderbar-->
    <!--<WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="20" CornerRadius="50" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>-->


    <Border CornerRadius="15" BorderThickness="3" BorderBrush="Black" Background="Black">
        <Border CornerRadius="10" BorderThickness="5"  >
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush >
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#555555" Offset="0.0"/>
                    <GradientStop Color="#333333" Offset="0.5"/>
                    <GradientStop Color="#555555" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#555555" Offset="0.0"/>
                        <GradientStop Color="#333333" Offset="0.5"/>
                        <GradientStop Color="#555555" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                
                <!-- Defenition Zeile -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!-- Defenition Spalten -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!--<Image HorizontalAlignment="Left">
                    <Image.Source>
                        <BitmapImage 
                            DecodePixelWidth="200"  
                            UriSource="/Images/IconDenon.ico">
                        </BitmapImage>  
                    </Image.Source>
                </Image>-->

                <!--<TextBlock TextWrapping="Wrap" Height="60" Margin="5,0,0,0"
                           FontSize="25" FontWeight="Medium"
                           VerticalAlignment="Top" HorizontalAlignment="Left"
                           > Denon AVR Office
                </TextBlock>-->
                
                
                <!-- Zeile 1 -->
                <Button x:Name="btnSettings" 
                        Width="131" 
                        HorizontalAlignment="Left"
                        Background="Transparent" 
                        Click="btnDenonSettings_Click"
                        Margin="5,-7,0,0"
                        FontSize="25"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        HorizontalContentAlignment="Left"
                        Style="{StaticResource HiddenButton}"
                        >
                    Denon AVR
                </Button>

                <Label
                    x:Name="DenonAVRName"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="135,-5,1,2"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="Transparent"
                    Foreground="Black" Grid.ColumnSpan="2"
                    >Name
                </Label>

                <TextBlock 
                   x:Name="Copyright1"
                   Text="Designed and Created by Georg Black"
                   Grid.Row="0"
                   Grid.Column="3"
                   Margin="0,0,0,0"
                   FontFamily="MV Boli"
                   FontSize="20"
                   Foreground="Lime"
                   TextWrapping="Wrap"
                   LineHeight="10"
                   FontWeight="Normal"
                   TextAlignment="Center">
                </TextBlock>

                <TextBlock 
                   x:Name="Copyright2"
                   Text="Georg Black"
                   Grid.Row="0"
                   Grid.Column="4"
                   Margin="0,0,0,0"
                   FontFamily="MV Boli"
                   FontSize="20"
                   Foreground="Lime"
                   TextWrapping="Wrap"
                   LineHeight="10"
                   FontWeight="Normal"
                   TextAlignment="Left">
                </TextBlock>

                <Grid 
                    Grid.Row="0"
                    Grid.Column="4">

                    <Button x:Name="btnSettings2" 
                        Width="40" 
                        HorizontalAlignment="Left"
                        Background="Transparent" 
                        Click="btnDenonSettings_Click"
                        Margin="128,0,0,0"
                        FontSize="25"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        HorizontalContentAlignment="Left"
                        Style="{StaticResource HiddenButton}"
                        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                                    ContentTemplate="{StaticResource Settings}"  
                                />
                            </Canvas>
                        </Viewbox>
                    </Button>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!--Minimize Button-->
                        <Button x:Name="btnMinimize" Width="30" Height="30"
                                BorderBrush="Transparent" 
                                Click="btnMinimize_Click" 
                                Style="{StaticResource MyMinimiButton}"
                                Margin="0,0,5,5">
                            <Viewbox>
                                <Canvas Width="10" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                    <ContentControl 
                                         ContentTemplate="{StaticResource MinimizedSymbol}" 
                                         Canvas.Left="-35" Canvas.Top="40"
                                     />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <!--Close Button-->
                        <Button x:Name="btnClose" Width="30" Height="30"
                                Style="{StaticResource MyCloseButton}"
                                Click="btnClose_Click"
                                Margin="0,0,5,5">
                            <Viewbox>
                                <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                    <ContentControl 
                                        ContentTemplate="{StaticResource CrossSymbol}" 
                                        Canvas.Left="10" Canvas.Top="10"
                                     />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
                <!-- Zeile 2 -->
                <Label
                    x:Name="Voice"
                    Margin="5"
                    FontSize="60"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    Grid.Row="1"
                    Grid.Column="3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Black"
                    BorderThickness="3"
                    >
                </Label>

                <Grid
                    Grid.Row="1"
                    Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="Taste_On" 
                        Style="{StaticResource ButtonStyle}"
                        Click =" Taste_OnOff_click"
                        Grid.Row="1"
                        Grid.Column="0"
                        >
                        <ContentControl 
                           ContentTemplate="{StaticResource PowerOnOff}" 
                         />
                    </Button>

                    <Button
                        x:Name="Taste_Mute" 
                        Style="{StaticResource ButtonStyle}"
                        Click =" Taste_Mute_click"
                        Grid.Row="1"
                        Grid.Column="1"
                        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                                   ContentTemplate="{StaticResource MuteSymbol}" 
                                 />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <Grid
                    Grid.Row="1"
                    Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="Taste_SelectV1" 
                        Style="{StaticResource ButtonStyleSelectV}"
                        Click="Taste_SelectV1_Click"
                        FontSize="26"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        >SelectV 1
                    </Button>

                    <Button
                        x:Name="Taste_SelectV2" 
                        Style="{StaticResource ButtonStyleSelectV}"
                        Click="Taste_SelectV2_Click"
                        FontSize="26"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="1"
                        >SelectV 2
                    </Button>
                    <Button
                        x:Name="Taste_SelectV3" 
                        Style="{StaticResource ButtonStyleSelectV}"
                        Click="Taste_SelectV3_Click"
                        FontSize="26"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="0"
                        >SelectV 3
                    </Button>
                    <Button
                        x:Name="Taste_SelectV4" 
                        Style="{StaticResource ButtonStyleSelectV}"
                        Click="Taste_SelectV4_Click"
                        FontSize="26"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="1"
                        >SelectV 4
                    </Button>
                </Grid>

                <Grid 
                Grid.Row="1"
                Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="Taste_VMinus2" 
                        Style="{StaticResource ButtonStyleV}"
                        Click="Taste_VMinus2_Click"
                        FontSize="50"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="0">

                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                 <ContentControl 
                                    ContentTemplate="{StaticResource SmallerSymbol}" 
                                    Canvas.Left="40" Canvas.Top="20"
                                 />
                                <ContentControl 
                                    ContentTemplate="{StaticResource SmallerSymbol}" 
                                    Canvas.Left="10" Canvas.Top="20"
                                 />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button
                        x:Name="Taste_VMinus" 
                        Style="{StaticResource ButtonStyleV}"
                        Click="Taste_VMinus_Click"
                        Margin="5"
                        FontSize="50"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="2">
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                                    ContentTemplate="{StaticResource SmallerSymbol}" 
                                    Canvas.Left="10" Canvas.Top="20"
                                 />
                                <ContentControl 
                                    ContentTemplate="{StaticResource MinusSymbol}" 
                                    Canvas.Left="45" Canvas.Top="10"
                                 />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <Grid 
                Grid.Row="1"
                Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="Taste_VPlus" 
                        Style="{StaticResource ButtonStyleV}"
                        Click="Taste_VPlus_Click"
                        FontSize="50"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="0"
                        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                                    ContentTemplate="{StaticResource BigerSymbol}" 
                                    Canvas.Left="50" Canvas.Top="20"
                                 />
                                <ContentControl 
                                    ContentTemplate="{StaticResource PlusSymbol}" 
                                    Canvas.Left="0" Canvas.Top="25"
                                 />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button
                        x:Name="Taste_VPlus2" 
                        Style="{StaticResource ButtonStyleV}"
                        Click="Taste_VPlus2_Click"
                        Margin="5"
                        FontSize="50"
                        FontWeight="Medium"
                        Grid.Row="1"
                        Grid.Column="2"
                        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                                    ContentTemplate="{StaticResource BigerSymbol}" 
                                    Canvas.Left="50" Canvas.Top="20"
                                 />
                                <ContentControl 
                                    ContentTemplate="{StaticResource BigerSymbol}" 
                                    Canvas.Left="20" Canvas.Top="20"
                                 />
                                </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
                <!-- Zeile 3 -->
                
                
                
                <Grid
                Grid.Row="2"
                Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="Taste_Select1" 
                        Style="{StaticResource ButtonStyle}"
                        Click="Taste_Select1_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="0"
                        >Select 1
                    </Button>

                    <Button
                        x:Name="Taste_Select2" 
                        Style="{StaticResource ButtonStyle}"
                        Click="Taste_Select2_Click"
                        FontSize="36"
                        FontWeight="Medium"
                        Grid.Row="0"
                        Grid.Column="1"
                        >Select 2
                    </Button>
                </Grid>

                <Grid
                Grid.Row="2"
                Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                 </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="Taste_Select3" 
                    Style="{StaticResource ButtonStyle}"
                    Click="Taste_Select3_Click"
                    FontSize="36"
                    FontWeight="Medium"
                    Grid.Row="0"
                    Grid.Column="0"
                    >Select 3
                </Button>

                <Button
                    x:Name="Taste_Select4" 
                    Style="{StaticResource ButtonStyle}"
                    Click="Taste_Select4_Click"
                    FontSize="36"
                    FontWeight="Medium"
                    Grid.Row="0"
                    Grid.Column="1"
                    >Select 4
                </Button>
                </Grid>


                <!-- Zeile 4 -->
                <Grid 
                    Grid.Row="2"
                    Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                    x:Name="Taste_WVMinus2" 
                    Style="{StaticResource ButtonStyleWV}"
                    Click="Taste_WVMinus2_Click"
                    FontSize="50"
                    FontWeight="Medium"
                    Grid.Row="1"
                    Grid.Column="0">

                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                    ContentTemplate="{StaticResource SmallerSymbol}" 
                    Canvas.Left="40" Canvas.Top="20"
                 />
                                <ContentControl 
                    ContentTemplate="{StaticResource SmallerSymbol}" 
                    Canvas.Left="10" Canvas.Top="20"
                 />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button
                    x:Name="Taste_WVMinus" 
                    Style="{StaticResource ButtonStyleWV}"
                    Click="Taste_WVMinus_Click"
                    Margin="5"
                    FontSize="50"
                    FontWeight="Medium"
                    Grid.Row="1"
                    Grid.Column="2">
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                    ContentTemplate="{StaticResource SmallerSymbol}" 
                    Canvas.Left="10" Canvas.Top="20"
                 />
                                <ContentControl 
                    ContentTemplate="{StaticResource MinusSymbol}" 
                    Canvas.Left="45" Canvas.Top="10"
                 />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>


                <Label
                    x:Name="WVoice"
                    Margin="5"
                    FontSize="60"
                    FontWeight="Medium"
                    Background="#555555"
                    Foreground="White"
                    Grid.Row="2"
                    Grid.Column="3"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Black"
                    BorderThickness="3"
                    >
                </Label>



                <Grid 
                Grid.Row="2"
                Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button
                    x:Name="Taste_WVPlus" 
                    Style="{StaticResource ButtonStyleWV}"
                    Click="Taste_WVPlus_Click"
                    FontSize="50"
                    FontWeight="Medium"
                    Grid.Row="1"
                    Grid.Column="0"
        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                    ContentTemplate="{StaticResource BigerSymbol}" 
                    Canvas.Left="50" Canvas.Top="20"
                 />
                                <ContentControl 
                    ContentTemplate="{StaticResource PlusSymbol}" 
                    Canvas.Left="0" Canvas.Top="25"
                 />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button
                    x:Name="Taste_WVPlus2" 
                    Style="{StaticResource ButtonStyleWV}"
                    Click="Taste_WVPlus2_Click"
                    Margin="5"
                    FontSize="50"
                    FontWeight="Medium"
                    Grid.Row="1"
                    Grid.Column="2"
        >
                        <Viewbox>
                            <Canvas Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" >
                                <ContentControl 
                    ContentTemplate="{StaticResource BigerSymbol}" 
                    Canvas.Left="50" Canvas.Top="20"
                 />
                                <ContentControl 
                    ContentTemplate="{StaticResource BigerSymbol}" 
                    Canvas.Left="20" Canvas.Top="20"
                 />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
